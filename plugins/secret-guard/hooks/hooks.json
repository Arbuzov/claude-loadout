{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git *)",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/secret-scan.mjs"],
            "statusMessage": "secret-guard: scanning staged changes",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
